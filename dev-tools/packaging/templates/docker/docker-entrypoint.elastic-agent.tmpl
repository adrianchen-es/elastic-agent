#!/bin/bash
{{- $beatHome := printf "%s/%s" "/usr/share" .BeatName }}

# Update umask to retain group write permissions on runtime directories: $root/tmp/default, $root/logs/default and $root/run/default
umask 0007

set -eo pipefail

# OpenShift runs containers with arbitrary UIDs in GID 0 (root group).
# Some tools (npm, node) require a valid passwd entry for the running user.
# If the current UID has no passwd entry, add one.
if ! whoami &>/dev/null; then
  if [ -w /etc/passwd ]; then
    echo "elastic-agent:x:$(id -u):$(id -g):elastic-agent:{{ $beatHome }}:/bin/bash" >> /etc/passwd
  fi
fi

# Custom CA certificate handling.
# Users can mount .crt files into {{ $beatHome }}/certs/ca/ to trust internal CAs.
# NODE_EXTRA_CA_CERTS is set in the Dockerfile to point to the bundle path.
CA_DIR="{{ $beatHome }}/certs/ca"
CA_BUNDLE="${CA_DIR}/ca-bundle.crt"
# Remove any stale bundle before scanning for mounted .crt files
rm -f "$CA_BUNDLE"
if [ -d "$CA_DIR" ] && compgen -G "$CA_DIR"/*.crt >/dev/null 2>&1; then
  # Concatenate all mounted .crt files into a single bundle for NODE_EXTRA_CA_CERTS
  cat "$CA_DIR"/*.crt > "$CA_BUNDLE" 2>/dev/null || true

  # Update system trust store if running as root
  if [ "$(id -u)" -eq 0 ]; then
    if command -v update-ca-trust &>/dev/null; then
      cp "$CA_DIR"/*.crt /etc/pki/ca-trust/source/anchors/ 2>/dev/null || true
      update-ca-trust || true
    elif command -v update-ca-certificates &>/dev/null; then
      cp "$CA_DIR"/*.crt /usr/local/share/ca-certificates/ 2>/dev/null || true
      update-ca-certificates || true
    fi
  fi
fi

# For information on the possible environment variables that can be passed into the container. Run the following
# command for information on the options that are available.
#
# `./elastic-agent container --help`
#

if [[ "$ELASTIC_AGENT_OTEL" == "true" ]]
then
exec {{ .BeatName }} otel "$@"
else
exec {{ .BeatName }} container "$@"
fi
